<?xml version="1.0" encoding="utf-8"?>
<resources>
    <style name="Theme.Luomashu" parent="android:Theme.Material.Light.NoActionBar">
        <item name="android:colorBackground">#FFFAF8F5</item>
        <item name="android:statusBarColor">#FFFAF8F5</item>
        <item name="android:navigationBarColor">#FFFAF8F5</item>
        <item name="android:windowLightStatusBar">true</item>
        <item name="android:windowAnimationStyle">@style/WindowAnim</item>
    </style>

    <style name="WindowAnim" parent="@android:style/Animation.Activity">
        <item name="android:activityOpenEnterAnimation">@anim/slide_in_right</item>
        <item name="android:activityOpenExitAnimation">@anim/no_anim</item>
        <item name="android:activityCloseEnterAnimation">@anim/no_anim</item>
        <item name="android:activityCloseExitAnimation">@anim/slide_out_right</item>
    </style>
</resources>
